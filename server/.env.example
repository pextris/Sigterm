# NETRUNNER Server Environment
# Copy this to .env and fill in values

# Your Anthropic API key — NEVER expose this to the client
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret — make this long and random
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Port to run on (default 3000)
PORT=3000

# SQLite database file path
DB_PATH=./netrunner.db

# Season length in days (default 180 = ~6 months)
SEASON_DAYS=180

# Admin panel password — set this to access /admin
# Leave blank to disable admin panel
ADMIN_PASSWORD=change-this-to-a-strong-password

# CORS origin — set to your frontend URL in production
# Use * for development, or your domain in production
CORS_ORIGIN=*
