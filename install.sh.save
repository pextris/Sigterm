c#!/bin/bash

# SIGTERM NODE INSTALLER
# They built the grid. We own it.

GREEN='\033[0;32m'
CYAN='\033[0;36m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

clear

echo -e "${GREEN}"
echo "  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą  ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą ‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėď‚Ėď‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą  ‚Ėą‚Ėą‚ĖÄ‚Ėą‚Ėą‚Ėą"
echo "  ‚Ėí‚Ėą‚Ėą    ‚Ėí ‚Ėą‚Ėą ‚Ėą‚Ėą  ‚ĖÄ‚Ėą ‚Ėď  ‚Ėą‚Ėą‚Ėí ‚Ėď‚Ėí‚Ėď‚Ėą   ‚ĖÄ ‚Ėď‚Ėą‚Ėą ‚Ėí ‚Ėą‚Ėą‚Ėí"
echo "  ‚ĖĎ ‚Ėď‚Ėą‚Ėą‚ĖĄ  ‚Ėą‚Ėą ‚Ėí‚Ėą‚Ėą‚ĖĎ‚ĖĄ‚ĖĄ‚ĖĄ ‚Ėí ‚Ėď‚Ėą‚Ėą‚ĖĎ ‚Ėí‚ĖĎ‚Ėí‚Ėą‚Ėą‚Ėą   ‚Ėď‚Ėą‚Ėą ‚ĖĎ‚ĖĄ‚Ėą ‚Ėí"
echo "    ‚Ėí   ‚Ėą‚Ėą‚ĖĎ‚Ėą‚Ėą ‚ĖĎ‚Ėď‚Ėą  ‚Ėą‚Ėą‚ĖĎ ‚Ėď‚Ėą‚Ėą‚Ėď ‚ĖĎ ‚Ėí‚Ėď‚Ėą  ‚ĖĄ ‚Ėí‚Ėą‚Ėą‚ĖÄ‚ĖÄ‚Ėą‚ĖĄ"
echo "  ‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚ĖĎ‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚Ėí‚Ėď‚Ėą‚Ėą‚Ėą‚ĖÄ‚Ėí  ‚Ėí‚Ėą‚Ėą‚Ėí ‚ĖĎ ‚ĖĎ‚Ėí‚Ėą‚Ėą‚Ėą‚Ėą‚Ėí‚ĖĎ‚Ėą‚Ėą‚Ėď ‚Ėí‚Ėą‚Ėą‚Ėí"
echo -e "${NC}"
echo -e "${CYAN}    They built the grid. We own it.${NC}"
echo ""
echo -e "${CYAN}// Checking dependencies...${NC}"
echo ""

if ! command -v node &> /dev/null; then
    echo -e "${RED}x Node.js not found. Install Node.js 18+ first.${NC}"
    echo "  https://nodejs.org"
    exit 1
fi
echo -e "${GREEN}+ Node.js $(node -v)${NC}"

if ! command -v npm &> /dev/null; then
    echo -e "${RED}x npm not found.${NC}"
    exit 1
fi
echo -e "${GREEN}+ npm $(npm -v)${NC}"

if ! command -v pm2 &> /dev/null; then
    echo -e "${CYAN}// Installing PM2...${NC}"
    npm install -g pm2
fi
echo -e "${GREEN}+ PM2 ready${NC}"
echo ""

echo -e "${CYAN}// NODE CONFIGURATION${NC}"
echo ""

echo -e "${GREEN}// What is your node name?${NC}"
echo -e "${DIM}   Example: OUTPOST-7, DARK_SIGNAL, THE_REFUGE${NC}"
read -p "   > " NODE_NAME
NODE_NAME=${NODE_NAME:-"SIGTERM-NODE"}
echo ""

echo -e "${GREEN}// What port? [3000]${NC}"
read -p "   > " PORT
PORT=${PORT:-3000}
echo ""

JWT_SECRET=$(node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
echo -e "${GREEN}+ Security key generated${NC}"
echo ""

echo -e "${GREEN}// Anthropic API key for AI narration? (y/n)${NC}"
echo -e "${DIM}   Game works without it. Get one at console.anthropic.com${NC}"
read -p "   > " HAS_ANTHROPIC
ANTHROPIC_KEY=""
if [[ "$HAS_ANTHROPIC" =~ ^[Yy]$ ]]; then
    echo -e "${GREEN}// Paste your key:${NC}"
    read -p "   > " ANTHROPIC_KEY
fi
echo ""

echo -e "${GREEN}// Set an admin password for /backstage:${NC}"
read -s -p "   > " ADMIN_PASSWORD
echo ""
echo ""

echo -e "${CYAN}// Writing config...${NC}"
cat > .env << ENV
NODE_NAME=$NODE_NAME
PORT=$PORT
JWT_SECRET=$JWT_SECRET
ANTHROPIC_API_KEY=$ANTHROPIC_KEY
ADMIN_PASSWORD=$ADMIN_PASSWORD
NODE_ENV=production
ENV
echo -e "${GREEN}+ Config written${NC}"

echo -e "${CYAN}// Installing dependencies...${NC}"
npm install --silent
cd client && npm install --silent
echo -e "${CYAN}// Building frontend...${NC}"
npm run build --silent
cd ..
echo -e "${GREEN}+ Frontend built${NC}"

echo -e "${CYAN}// Starting node...${NC}"
pm2 delete sigterm 2>/dev/null || true
pm2 start server/index.js --name sigterm
pm2 save

echo ""
echo -e "${GREEN}+ YOUR NODE IS LIVE.${NC}"
echo ""
echo -e "${CYAN}  Running on:  ${NC}http://localhost:$PORT"
echo -e "${CYAN}  Admin panel: ${NC}http://localhost:$PORT/backstage"
echo ""
echo -e "${GREEN}  Welcome to the resistance.${NC}"
echo ""
